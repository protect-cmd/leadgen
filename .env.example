# BatchData
BATCHDATA_API_KEY=

# SearchBug — tenant people search for yellow calendar sources (name + city/state → phone)
SEARCHBUG_CO_CODE=
SEARCHBUG_API_KEY=
SEARCHBUG_DAILY_CAP=100

# Enrichment track switches
# TENANT_TRACK_ENABLED — NG (Vantage Defense / tenant) enrichment. Default on.
# LANDLORD_TRACK_ENABLED — EC (Grant Ellis / landlord) enrichment. Default off.
# Set LANDLORD_TRACK_ENABLED=true on any environment that needs EC enrichment.
# Both cannot be false simultaneously — the runner will raise a RuntimeError.
# YELLOW_SECOND_CALL_ENABLED — if true, a yellow address-only SearchBug hit escalates to
#   a second paid BatchData call. Default off (phone+address hits never escalate regardless).
TENANT_TRACK_ENABLED=true
LANDLORD_TRACK_ENABLED=false
YELLOW_SECOND_CALL_ENABLED=false

# Optional rent precheck before BatchData. Default is off and fail-open.
RENT_PRECHECK_ENABLED=false
RENT_PRECHECK_PROVIDER=rentometer
RENTOMETER_API_KEY=
RENTOMETER_BEDROOMS=2
RENTOMETER_BATHS=
RENTOMETER_BUILDING_TYPE=
RENTOMETER_LOOK_BACK_DAYS=

# Google Geocoding — optional; normalizes addresses before BatchData enrichment
GOOGLE_GEOCODING_API_KEY=

# GHL — shared agency API key, separate subaccount location IDs per brand
GHL_API_KEY=
GHL_EC_LOCATION_ID=
GHL_NEW_FILING_STAGE_ID=
GHL_EC_REVIEW_STAGE_ID=
# NG subaccount — fill in once created
GHL_NG_LOCATION_ID=
GHL_NG_NEW_FILING_STAGE_ID=
GHL_NG_COMMERCIAL_STAGE_ID=
GHL_WEBHOOK_SECRET=

# Bland.ai
BLAND_ENABLED=false
BLAND_TEST_CALLS_ENABLED=false
AUTO_BLAND_CALLS_ENABLED=false
BLAND_API_KEY=
BLAND_EC_AGENT_ID=
BLAND_NG_AGENT_ID=
BLAND_NG_SPANISH_AGENT_ID=
BLAND_EC_PHONE_NUMBER=
BLAND_NG_PHONE_NUMBER=
BLAND_NG_SPANISH_PHONE_NUMBER=
BLAND_EC_CALLBACK_PHONE_NUMBER=
BLAND_NG_CALLBACK_PHONE_NUMBER=
BLAND_NG_SPANISH_CALLBACK_PHONE_NUMBER=

# Instantly.ai email enrollment. Default off; enables external API writes.
INSTANTLY_ENABLED=false
INSTANTLY_API_KEY=
INSTANTLY_EC_CAMPAIGN_ID=
INSTANTLY_NG_CAMPAIGN_ID=

# DNC / outreach safety
# Current automated gate uses BatchData's selected-phone DNC flag.
# Use a scrub vendor value once credentials are available, for example dncscrub.
DNC_PROVIDER=batchdata
DNC_FAIL_CLOSED=true

# Pushover alerts — optional phone notifications for scraper/service errors.
PUSHOVER_ENABLED=false
PUSHOVER_APP_TOKEN=
PUSHOVER_USER_KEY=
PUSHOVER_USER_KEYS=

# Supabase
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# re:SearchGA (Georgia — free account at researchga.tylerhost.net)
RESEARCHGA_EMAIL=
RESEARCHGA_PASSWORD=

# Scheduler — controls the in-process daily scrape cron inside the dashboard service.
# Defaults to enabled when RAILWAY_SERVICE_NAME=leadgen; set explicitly to override.
DASHBOARD_DAILY_SCHEDULER_ENABLED=true

# Service
ENVIRONMENT=production
LOG_LEVEL=INFO
