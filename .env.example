# BatchData
BATCHDATA_API_KEY=

# SearchBug — tenant people search (name + city/state → phone).
# Used by both yellow-source (no property address) and green-source (BatchData
# returned no name match) tenant enrichment paths. Both paths share the same
# cost gates: cache lookup, common-surname filter, daily cap.
#
# SEARCHBUG_CACHE_DB_PATH: where to store the cache + daily-cap counter. On
# Railway, point at the persistent volume so it survives redeploys. Default
# is data/enrichment_cache.db (ephemeral inside the container).
SEARCHBUG_CO_CODE=
SEARCHBUG_API_KEY=
SEARCHBUG_DAILY_CAP=100
SEARCHBUG_CACHE_DB_PATH=data/enrichment_cache.db

# Enrichment track switches
# TENANT_TRACK_ENABLED — NG (Vantage Defense / tenant) enrichment. Default on.
# LANDLORD_TRACK_ENABLED — EC (Grant Ellis / landlord) enrichment. Default off.
# Set LANDLORD_TRACK_ENABLED=true on any environment that needs EC enrichment.
# Both cannot be false simultaneously — the runner will raise a RuntimeError.
TENANT_TRACK_ENABLED=true
LANDLORD_TRACK_ENABLED=false

# Optional rent precheck before BatchData. Default is off and fail-open.
# RENT_PRECHECK_PROVIDER: "rentometer" (paid, per-address market estimate) or
# "hud"/"safmr" (free, ZIP-level HUD Small Area FMR; no API key, no rate limit).
RENT_PRECHECK_ENABLED=false
RENT_PRECHECK_PROVIDER=rentometer
RENTOMETER_API_KEY=
RENTOMETER_BEDROOMS=2
RENTOMETER_BATHS=
RENTOMETER_BUILDING_TYPE=
RENTOMETER_LOOK_BACK_DAYS=
# HUD SAFMR provider — overrides the bundled table path / bedroom size if set.
HUD_SAFMR_DATA_PATH=
HUD_SAFMR_BEDROOMS=2

# Google Geocoding — optional; normalizes addresses before BatchData enrichment
GOOGLE_GEOCODING_API_KEY=

# LLM recovery — Qwen via OpenRouter rescues filings rejected by gate_address /
# gate_name when court records have messy formatting. Only fires on regex
# rejections; never on healthy leads. Disabled by default — flip ENABLED=true
# after seeding the API key.
LLM_RECOVERY_ENABLED=false
OPENROUTER_API_KEY=
LLM_RECOVERY_MODEL=qwen/qwen-2.5-7b-instruct

# Lead-capture behaviour
# CAPTURE_EXPANDED_ZIPS — when true (default), filings outside the legacy ZIP allowlist
#   land in lead_bucket='captured' instead of 'discarded'. Set to false to revert to
#   the old EC-era ZIP-filter-only behaviour.
# ENRICHMENT_WINDOW_DAYS — gate: only enrich filings filed within this many days.
#   Default 10 days. Lower to reduce SearchBug spend; raise to catch older backlog.
CAPTURE_EXPANDED_ZIPS=true
# BYPASS_ZIP_FILTER — when true, off-allowlist ZIPs are treated as approved and
# flow through the full enrichment pipeline. Overrides CAPTURE_EXPANDED_ZIPS.
# Default false so the legacy allowlist still applies.
BYPASS_ZIP_FILTER=false
ENRICHMENT_WINDOW_DAYS=10

# GHL — shared agency API key, separate subaccount location IDs per brand
GHL_API_KEY=
GHL_EC_LOCATION_ID=
GHL_NEW_FILING_STAGE_ID=
GHL_EC_REVIEW_STAGE_ID=
# NG subaccount — fill in once created
GHL_NG_LOCATION_ID=
GHL_NG_NEW_FILING_STAGE_ID=
GHL_NG_COMMERCIAL_STAGE_ID=
# NG review stage — name_mismatch/ambiguous SearchBug leads land here for human vetting.
# Skip Instantly and Bland until promoted. Leave blank to drop review-stage leads.
GHL_NG_REVIEW_STAGE_ID=
GHL_WEBHOOK_SECRET=
# Cosner Drake subaccount (debt-claim Answer-window leads) — Private Integration Token
GHL_API_CD_KEY=
GHL_CD_LOCATION_ID=
GHL_CD_NEW_LEAD_STAGE_ID=

# Bland.ai
BLAND_ENABLED=false
BLAND_TEST_CALLS_ENABLED=false
AUTO_BLAND_CALLS_ENABLED=false
BLAND_API_KEY=
BLAND_EC_AGENT_ID=
BLAND_NG_AGENT_ID=
BLAND_NG_SPANISH_AGENT_ID=
BLAND_EC_PHONE_NUMBER=
BLAND_NG_PHONE_NUMBER=
BLAND_NG_SPANISH_PHONE_NUMBER=
BLAND_EC_CALLBACK_PHONE_NUMBER=
BLAND_NG_CALLBACK_PHONE_NUMBER=
BLAND_NG_SPANISH_CALLBACK_PHONE_NUMBER=

# Instantly.ai email enrollment. Default off; enables external API writes.
INSTANTLY_ENABLED=false
INSTANTLY_API_KEY=
INSTANTLY_EC_CAMPAIGN_ID=
INSTANTLY_NG_CAMPAIGN_ID=

# Pushover alerts — optional phone notifications for scraper/service errors.
PUSHOVER_ENABLED=false
PUSHOVER_APP_TOKEN=
PUSHOVER_USER_KEY=
PUSHOVER_USER_KEYS=

# Supabase
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# re:SearchGA (Georgia — free account at researchga.tylerhost.net)
RESEARCHGA_EMAIL=
RESEARCHGA_PASSWORD=

# Bright Data scraping browser — required for Tarrant TX (run_tarrant.py).
# BRIGHTDATA_SB_WS overrides everything; otherwise customer/zone/password are
# combined into the websocket URL.
BRIGHTDATA_SB_WS=
BRIGHTDATA_CUSTOMER_ID=
BRIGHTDATA_ZONE=
BRIGHTDATA_ZONE_PASSWORD=

# Scheduler — controls the in-process daily scrape cron inside the dashboard service.
# Defaults to enabled when RAILWAY_SERVICE_NAME=leadgen; set explicitly to override.
DASHBOARD_DAILY_SCHEDULER_ENABLED=true

# Service
ENVIRONMENT=production
LOG_LEVEL=INFO
